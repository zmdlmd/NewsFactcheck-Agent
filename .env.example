# OpenAI-compatible LLM
MODEL_NAME=qwen-plus
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=your-embedding-model
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://your-embedding-endpoint/v1

# Search provider
TAVILY_API_KEY=your-tavily-api-key

# Retrieval mode
RETRIEVAL_MODE=web
RAG_BACKEND=qdrant
RAG_COLLECTION=factcheck_corpus
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0
RERANK_MODE=off
RERANK_MAX_CANDIDATES=8
RERANK_DIVERSITY_WEIGHT=6.0
RETRIEVAL_DIAGNOSTICS_ENABLED=1
RAG_INDEX_DIR=./data/rag_index
RAG_DOCS_DIR=./data/rag_corpus

# Workflow limits
MAX_CLAIMS=5
SEARCH_BUDGET=10
MAX_ROUNDS_PER_CLAIM=2

# Fetch controls
ENABLE_FETCH=0
FETCH_BUDGET=4
FETCH_CACHE_ENABLED=1
FETCH_CACHE_TTL_SECONDS=86400
FETCH_MAX_BYTES=4000000
FETCH_MIN_TEXT_CHARS=80
FETCH_MIN_TEXT_RATIO=0.45

# Search cache
SEARCH_CACHE_ENABLED=1
SEARCH_CACHE_TTL_SECONDS=86400

# Storage
DATA_DIR=./data
